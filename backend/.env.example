# ═══════════════════════════════════════════════════════════════
# DCP Digital Twin — Environment Configuration
# Copy this file to .env and modify values for your environment
# ═══════════════════════════════════════════════════════════════

# ─── Database ───
DATABASE_URL=sqlite:///./digital_twin_production.db

# ─── API Server ───
API_HOST=0.0.0.0
API_PORT=8000

# ─── Authentication (JWT) ───
AUTH_ENABLED=true
JWT_SECRET_KEY=change-this-to-a-random-64-char-string-in-production
JWT_EXPIRE_MINUTES=30

# ─── OPC-UA Server ───
OPCUA_ENABLED=true
OPCUA_ENDPOINT=opc.tcp://0.0.0.0:4840/dcp-twin/
OPCUA_NAMESPACE=http://dcp-digital-twin/

# ─── Batch Records ───
BATCH_RECORDS_DIR=data/batch_records

# ─── Simulation ───
SIMULATION_TICK_MS=100
REACTOR_VOLUME_LITERS=10.0

# ─── Logging ───
LOG_LEVEL=INFO
LOG_DIR=logs
